generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          String   @id @default(cuid())
  nombre      String
  cif         String   @default("")
  dir         String   @default("")
  cp          String   @default("")
  ciudad      String   @default("")
  prov        String   @default("")
  mail        String   @default("")
  tel         String   @default("")
  customData  String   @default("")     // JSON: custom field values
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registros Registro[]
  catalogo  Catalogo[]
}

model Catalogo {
  id          String   @id @default(cuid())
  clienteId   String   @default("")
  c1          String
  c2          String
  coste       Float    @default(0)
  inc         Float    @default(0)
  final       Float    @default(0)
  customData  String   @default("")     // JSON: custom field values
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente Cliente? @relation(fields: [clienteId], references: [id])
}

model Registro {
  id              String   @id @default(cuid())
  fecha           String
  clienteId       String
  cliente         String   @default("")
  c1              String
  c2              String
  cant            Int      @default(1)
  obs             String   @default("")
  pasadoRegistro  Boolean  @default(false)  // true = ya transferido a Registros
  facturado       Boolean  @default(false)  // true = ya facturado
  customData      String   @default("")     // JSON: custom field values
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clienteRel Cliente? @relation(fields: [clienteId], references: [id])
}

model FacturaSeq {
  id    String @id @default("main")
  seq   Int    @default(1)
}

model Config {
  id              String   @id @default("main")
  companyName     String   @default("HUALSA PRO")
  companyFullName String   @default("Transportes Hualsa 2021, S.L.")
  companyAddress  String   @default("C/ Moret y Aleson, Nº 30")
  companyCity     String   @default("31320 Milagro")
  companyProvince String   @default("Navarra")
  companyCif      String   @default("")
  logo            String   @default("")   // base64 encoded logo image
  currency        String   @default("€")
  defaultIva      Float    @default(21)
  appName         String   @default("HUALSA PRO")
  appVersion      String   @default("v2.0")
  // Configurable section labels (JSON strings)
  labelEntrada    String   @default("")   // JSON: { fecha, cliente, c1, c2, cantidad, observaciones }
  labelCatalogo   String   @default("")   // JSON: { c1, c2, coste, incremento, precioCliente, cliente }
  labelRegistros  String   @default("")   // JSON: { fecha, mes, semana, cliente, c1, c2, cantidad, precioUnitario, importe, observaciones }
  labelFacturas   String   @default("")   // JSON: { numero, fecha, cliente, concepto, cantidad, precioUnitario, importe, baseImponible, totalFactura }
  labelClientes   String   @default("")   // JSON: { nombre, cif, direccion, cp, ciudad, provincia, mail, telefono }
  // Section names
  sectionEntrada  String   @default("ENTRADA")
  sectionRegistros String  @default("REGISTROS")
  sectionClientes String   @default("CLIENTES")
  sectionCatalogo String   @default("CATÁLOGO")
  sectionFacturas String   @default("FACTURAS")
  sectionBackup   String   @default("SEGURIDAD")
  // Transfer settings
  transferMode    String   @default("auto")   // "auto" or "manual"
  transferTime    String   @default("00:00")  // HH:mm for auto transfer
  // Visible fields (JSON arrays of field definitions with key, label, type, visible, isCustom)
  fieldsEntrada   String   @default("")   // JSON: FieldDef[]
  fieldsClientes  String   @default("")   // JSON: FieldDef[]
  fieldsCatalogo  String   @default("")   // JSON: FieldDef[]
  fieldsRegistros String   @default("")   // JSON: FieldDef[]
  fieldsFacturas  String   @default("")   // JSON: FieldDef[]
  updatedAt       DateTime @updatedAt
}
